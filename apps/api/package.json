{
  "name": "@oficios/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src prisma --ext .ts",
    "test": "node -e \"console.log('API tests pending')\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.11",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/swagger": "^11.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@oficios/config": "workspace:*",
    "@oficios/contracts": "workspace:*",
    "@oficios/domain": "workspace:*",
    "@oficios/utils": "workspace:*",
    "@prisma/client": "^6.4.1",
    "argon2": "^0.41.1",
    "bullmq": "^5.43.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.5.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.4.1",
    "tsx": "^4.19.3"
  }
}

