{
  "name": "@oficios/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:deps": "pnpm --filter @oficios/config build",
    "dev": "pnpm run build:deps && tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "pnpm run build:deps && tsx src/main.ts",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "node -e \"console.log('Worker tests pending')\""
  },
  "dependencies": {
    "@oficios/config": "workspace:*",
    "bullmq": "^5.43.0",
    "ioredis": "^5.5.0"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}

